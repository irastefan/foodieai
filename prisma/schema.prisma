generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductScope {
  GLOBAL
  USER
}

enum ProductStatus {
  VERIFIED
  PENDING_REVIEW
}

enum ProductSource {
  INTERNAL
  FATSECRET
  AI_ESTIMATED
}

enum RecipeVisibility {
  PRIVATE
  PUBLIC
}

enum Sex {
  FEMALE
  MALE
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  VERY_ACTIVE
}

enum GoalType {
  MAINTAIN
  LOSE
  GAIN
}

enum TargetFormula {
  MIFFLIN_ST_JEOR
  HARRIS_BENEDICT_ORIGINAL
  HARRIS_BENEDICT_REVISED
  OWEN
}

enum MacroProfile {
  BALANCED
  HIGH_PROTEIN
  LOW_CARB
  HIGH_CARB
}

enum SubscriptionStatus {
  FREE
  TRIAL
  ACTIVE
  EXPIRED
}

enum AiFeature {
  RECIPE_GENERATION
  MEAL_ANALYSIS
  SMART_PRODUCT_MATCH
  ADVANCED_AI_TOOLS
}

enum MealSlot {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum MealEntryType {
  PRODUCT
  RECIPE
}

enum RoutineWeekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  passwordHash       String
  externalId         String?            @unique
  createdAt          DateTime           @default(now())
  profile            UserProfile?
  aiSubscription     UserAiSubscription?
  aiUsageLogs        AiUsageLog[]
  bodyMetricEntries  UserBodyMetricEntry[]
  mealPlanDays       MealPlanDay[]
  shoppingLists      ShoppingList[]
  shoppingCategories ShoppingCategory[]
  products           Product[]
  recipes            Recipe[]
  selfCareSlots      SelfCareRoutineSlot[]
}

model UserProfile {
  id            String         @id @default(cuid())
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName     String?
  lastName      String?

  sex           Sex?
  birthDate     DateTime?
  heightCm      Int?
  weightKg      Float?
  activityLevel ActivityLevel?
  goal          GoalType?      @default(MAINTAIN)
  targetFormula TargetFormula  @default(MIFFLIN_ST_JEOR)
  macroProfile  MacroProfile   @default(BALANCED)

  targetCalories Int?
  targetProteinG Int?
  targetFatG     Int?
  targetCarbsG   Int?

  calorieDelta  Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model AiPlan {
  id                String               @id @default(cuid())
  name              String
  code              String               @unique
  monthlyTokenLimit Int
  monthlyAiActions  Int?
  priceCents        Int
  currency          String               @default("USD")
  isActive          Boolean              @default(true)
  features          AiPlanFeature[]
  subscriptions     UserAiSubscription[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model AiPlanFeature {
  id        String    @id @default(cuid())
  planId    String
  plan      AiPlan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  feature   AiFeature
  createdAt DateTime  @default(now())

  @@unique([planId, feature])
  @@index([feature])
}

model UserAiSubscription {
  id                 String             @id @default(cuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionStatus SubscriptionStatus @default(FREE)
  planId             String?
  plan               AiPlan?            @relation(fields: [planId], references: [id], onDelete: SetNull)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  tokensUsed         Int                @default(0)
  tokensLimit        Int                @default(0)
  trialStartedAt     DateTime?
  trialEndsAt        DateTime?
  trialTokenLimit    Int?
  usageLogs          AiUsageLog[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model AiUsageLog {
  id               String     @id @default(cuid())
  userId           String
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId   String?
  subscription     UserAiSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  actionType       String
  feature          AiFeature?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int
  model            String
  createdAt        DateTime   @default(now())

  @@index([userId, createdAt])
  @@index([subscriptionId, createdAt])
  @@index([feature, createdAt])
}

model UserBodyMetricEntry {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         DateTime
  weightKg     Float?
  measurements Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

model Product {
  id             String        @id @default(cuid())
  name           String
  brand          String?
  normalizedName String
  scope          ProductScope
  status         ProductStatus
  ownerUserId    String
  owner          User          @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  source         ProductSource
  kcal100        Int
  protein100     Float
  fat100         Float
  carbs100       Float
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  recipeIngredients      RecipeIngredient[]
  mealPlanEntries        MealPlanEntry[]
  shoppingListItems      ShoppingListItem[]

  @@index([normalizedName])
}

model Recipe {
  id          String           @id @default(cuid())
  ownerUserId String
  owner       User             @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  title       String
  category    String?
  description String?
  servings    Int?
  visibility  RecipeVisibility @default(PRIVATE)

  ingredients RecipeIngredient[]
  steps       RecipeStep[]
  mealPlanEntries MealPlanEntry[]

  nutritionTotal      Json?
  nutritionPerServing Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RecipeIngredient {
  id           String  @id @default(cuid())
  recipeId     String
  recipe       Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  order        Int?
  originalText String?
  name         String
  amount       Float?
  unit         String?

  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  isManual    Boolean  @default(false)

  kcal100     Float?
  protein100  Float?
  fat100      Float?
  carbs100    Float?
  assumptions Json?

  nutritionTotal      Json?
  nutritionPerServing Json?
}

model RecipeStep {
  id       String @id @default(cuid())
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  order    Int
  text     String
}

model IdempotencyKey {
  id        String   @id @default(cuid())
  key       String
  operation String
  entityId  String?
  result    Json?
  createdAt DateTime @default(now())

  @@unique([operation, key, entityId])
}

model ShoppingList {
  id          String             @id @default(cuid())
  ownerUserId String
  owner       User               @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  title       String             @default("My shopping list")
  items       ShoppingListItem[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([ownerUserId])
}

model ShoppingCategory {
  id             String               @id @default(cuid())
  ownerUserId    String
  owner          User                 @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  name           String
  normalizedName String
  items          ShoppingListItem[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([ownerUserId, normalizedName])
}

model ShoppingListItem {
  id          String            @id @default(cuid())
  listId      String
  list        ShoppingList      @relation(fields: [listId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?          @relation(fields: [productId], references: [id])
  customName  String?
  amount      Float?
  unit        String?
  note        String?
  isDone      Boolean           @default(false)
  categoryId  String?
  category    ShoppingCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([listId, isDone])
}

model MealPlanDay {
  id             String        @id @default(cuid())
  ownerUserId    String
  owner          User          @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  date           DateTime
  nutritionBySlot Json?
  nutritionTotal  Json?
  entries        MealPlanEntry[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([ownerUserId, date])
}

model MealPlanEntry {
  id            String        @id @default(cuid())
  dayId         String
  day           MealPlanDay   @relation(fields: [dayId], references: [id], onDelete: Cascade)
  slot          MealSlot
  entryType     MealEntryType
  order         Int

  customName    String?
  productId     String?
  product       Product?      @relation(fields: [productId], references: [id])
  recipeId      String?
  recipe        Recipe?       @relation(fields: [recipeId], references: [id])
  isManual      Boolean       @default(false)

  amount        Float?
  unit          String?
  servings      Float?
  nutritionPer100 Json?
  nutritionTotal Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([dayId, slot])
  @@unique([dayId, slot, order])
}

model SelfCareRoutineSlot {
  id             String                @id @default(cuid())
  ownerUserId    String
  owner          User                  @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  weekday        RoutineWeekday
  name           String
  normalizedName String
  order          Int
  items          SelfCareRoutineItem[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([ownerUserId, weekday, order])
  @@unique([ownerUserId, weekday, normalizedName])
  @@unique([ownerUserId, weekday, order])
}

model SelfCareRoutineItem {
  id          String              @id @default(cuid())
  slotId       String
  slot         SelfCareRoutineSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  note         String?
  order        Int
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([slotId, order])
  @@unique([slotId, order])
}
