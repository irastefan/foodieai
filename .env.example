DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
PORT=3000
MCP_API_KEY=changeme
DEV_AUTH_BYPASS_SUB=dev-user
JWT_SECRET=replace-with-at-least-16-characters
BODY_LIMIT=20mb
AI_FREE_PLAN_MONTHLY_TOKEN_LIMIT=25000
AI_FREE_PLAN_MONTHLY_AI_ACTIONS=5
AI_FREE_PLAN_PRICE_CENTS=0
AI_ACTIVE_PLAN_MONTHLY_TOKEN_LIMIT=500000
AI_ACTIVE_PLAN_MONTHLY_AI_ACTIONS=100
AI_ACTIVE_PLAN_PRICE_CENTS=999
AI_TRIAL_TOKEN_LIMIT=100000
AI_TRIAL_DAYS=14
GCS_UPLOAD_BUCKET=your-gcs-bucket
GCS_UPLOAD_PUBLIC=false
GCS_UPLOAD_URL_TTL_SECONDS=900
GCS_UPLOAD_MAX_FILE_BYTES=10485760
GCS_UPLOAD_PATH_PREFIX=ai-input-images
